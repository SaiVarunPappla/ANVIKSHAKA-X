# AI Provider Configuration
# Options: "gemini", "ollama", "auto", "rule-based"
# - "auto": Prefer Gemini if GEMINI_API_KEY is set, otherwise try Ollama, then rule-based
# - "gemini": Use Google Gemini API (requires GEMINI_API_KEY)
# - "ollama": Use local Ollama server (requires Ollama running)
# - "rule-based": Disable AI completely, use rule-based logic only
AI_PROVIDER=auto

# Gemini Configuration (for production/hosted deployments)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Ollama Configuration (for local/offline deployments)
# The ollama-python library uses OLLAMA_HOST environment variable
# Set OLLAMA_HOST to custom URL if not using default localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Database Configuration
# For development: SQLite (default)
# For production: PostgreSQL (Supabase, Vercel Postgres, etc.)
#
# Priority order (first valid URL found will be used):
# 1. DATABASE_URL
# 2. POSTGRES_URL_NON_POOLING (recommended for serverless - direct connection)
# 3. POSTGRES_URL (connection pooling, may have timeout issues on serverless)
#
# The backend will automatically:
# - Strip whitespace and quotes
# - Remove accidental "ENV_NAME=" prefixes
# - Convert postgres:// to postgresql:// for SQLAlchemy compatibility
#
# Examples:
# DATABASE_URL=sqlite:///./anvikshaka.db
# DATABASE_URL=postgresql://user:pass@db.supabase.co:5432/postgres
# POSTGRES_URL_NON_POOLING=postgres://user:pass@aws-xxx.pooler.supabase.com:5432/postgres

# CORS Configuration (Backend only)
# Set this to your deployed frontend URL in production
# Example: FRONTEND_URL=https://anvikshaka-x-frontend.vercel.app
FRONTEND_URL=

# Frontend API URL (Frontend only)
# Set this in frontend Vercel project to point to deployed backend
# Example: VITE_API_URL=https://anvikshaka-x-backend.vercel.app/api
# For local development, use: http://localhost:8000/api

# Database Seeding (optional - useful for development)
# Set to "true" to seed sample data on startup
# Set to "false" for production to reduce cold start time
SEED_DATABASE=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
